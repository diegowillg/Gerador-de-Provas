<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">

    <display-name>Gerador de Provas</display-name>

    <!-- Quando o usuario acessa a raiz do sistema, envia para /home. -->
    <welcome-file-list>
        <welcome-file>home</welcome-file>
    </welcome-file-list>

    <!-- Tempo de sessao usado para mensagens temporarias e navegacao. -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <!-- Garante que as paginas JSP sejam interpretadas como UTF-8. -->
    <jsp-config>
        <jsp-property-group>
            <url-pattern>*.jsp</url-pattern>
            <page-encoding>UTF-8</page-encoding>
            <default-content-type>text/html</default-content-type>
        </jsp-property-group>
    </jsp-config>

    <!-- Pagina amigavel para rotas inexistentes. -->
    <error-page>
        <error-code>404</error-code>
        <location>/WEB-INF/views/erro.jsp</location>
    </error-page>

    <!-- Qualquer excecao nao tratada tambem cai na tela de erro. -->
    <error-page>
        <exception-type>java.lang.Exception</exception-type>
        <location>/WEB-INF/views/erro.jsp</location>
    </error-page>
</web-app>
